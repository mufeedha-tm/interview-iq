# ─── Server ────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# Set to "true" when deploying on Render — enables Render-specific error messages
RENDER=true

# ─── Client ────────────────────────────────────────────────
CLIENT_URL=https://interview-iq-ruddy-one.vercel.app,https://interview-*.vercel.app,http://localhost:5173,http://127.0.0.1:5173

# ─── Database ──────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/interviewiq?retryWrites=true&w=majority&appName=Cluster0

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
JWT_REFRESH_EXPIRES_IN=7d

# ─── Email (Gmail + Nodemailer) ────────────────────────────
# Use a Gmail App Password (not your regular Gmail password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_SERVICE=gmail
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-16-char-app-password
EMAIL_FROM=your-gmail@gmail.com
EMAIL_FROM_NAME=InterviewIQ

# OTP behaviour
OTP_EMAIL_TIMEOUT_MS=30000       # Max ms to wait for email send (30s recommended on Render)
OTP_RESEND_COOLDOWN_MS=60000     # Cooldown between resend requests (60s)

# Gmail SMTP connection timeouts — increase these on Render to prevent timeout errors
EMAIL_CONNECTION_TIMEOUT_MS=15000
EMAIL_GREETING_TIMEOUT_MS=15000
EMAIL_SOCKET_TIMEOUT_MS=30000

# ─── Cloudinary ────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ─── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-test-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
